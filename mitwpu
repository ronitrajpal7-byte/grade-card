            <th>Grade</th>
            <th>Grade Point</th>
        </tr>

        <tr><td>1</td><td>BIB3PM01A</td><td>3</td><td>Foreign Exchange Operations</td><td>B+</td><td>21</td></tr>
        <tr><td>2</td><td>BIB3PM02A</td><td>3</td><td>Foreign Language German - I</td><td>A</td><td>24</td></tr>
        <tr><td>3</td><td>BIB3PM03A</td><td>2</td><td>WTO and Trading Blocs</td><td>B</td><td>12</td></tr>
        <tr><td>4</td><td>BIB3PE13A</td><td>4</td><td>International Financial Management</td><td>B+</td><td>21</td></tr>
        <tr><td>5</td><td>BIB3PR01A</td><td>4</td><td>Internship</td><td>A</td><td>32</td></tr>
        <tr><td>6</td><td>BIB3PR02A</td><td>1</td><td>Project Based Learning - III</td><td>A</td><td>8</td></tr>
        <tr><td>7</td><td>PCE3UC03A</td><td>2</td><td>Managing Conflicts Peacefully: Tools and Techniques</td><td>A+</td><td>18</td></tr>
        <tr><td>8</td><td>MAC3UE01A</td><td>4</td><td>Leveraging Social Media for Personal Branding</td><td>A+</td><td>36</td></tr>
    </table>

    <div class="footer">
        <div><span>Medium of Instruction: English</span><span>Semester Credits Earned: 23</span></div>
        <div><span>Remark: PASS</span><span>GPA: 7.70 | CGPA: 6.57</span></div>
    </div>

</div>

<script>
function login() {
    const email = document.getElementById("email").value;
    const password = document.getElementById("password").value;

    if (email === "gurpreetrajpal@mitwpu.edu.in" && password === "sob2026") {
        document.getElementById("loginPage").style.display = "none";
        document.getElementById("reportCard").style.display = "block";
    } else {
        document.getElementById("errorMsg").style.display = "block";
    }
}

function resetForm() {
    document.getElementById("email").value = "";
    document.getElementById("password").value = "";
    document.getElementById("errorMsg").style.display = "none";
}
</script>

</body>
</html>
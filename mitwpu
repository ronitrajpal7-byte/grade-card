<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>CAS Portal</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #f2f2f2;
}

/* Container */
.container {
    max-width: 500px;
    margin: 40px auto;
    background: white;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    overflow: hidden;
}

/* Header */
.header {
    background: #2f3e75;
    color: white;
    padding: 20px;
    text-align: center;
}

/* Login */
.login-box {
    padding: 20px;
    text-align: center;
}

.login-box h1 {
    color: #d43f5e;
}

input {
    width: 90%;
    padding: 12px;
    margin: 10px 0;
    border-radius: 25px;
    border: 1px solid #ccc;
}

button {
    padding: 10px 25px;
    border-radius: 20px;
    border: none;
    margin: 10px;
    cursor: pointer;
}

.error {
    color: red;
    display: none;
}

/* Grade Card */
#reportCard {
    display: none;
    padding: 20px;
}

.grade-title {
    text-align: center;
    font-weight: bold;
    font-size: 20px;
}

.info {
    margin-top: 15px;
}

.info div {
    display: flex;
    justify-content: space-between;
    margin: 5px 0;
}

table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 15px;
    font-size: 12px;
}

table, th, td {
    border: 1px solid black;
}

th, td {
    padding: 6px;
    text-align: center;
}

.footer {
    margin-top: 15px;
    font-size: 13px;
}

.footer div {
    display: flex;
    justify-content: space-between;
    margin-top: 5px;
}
</style>
</head>

<body>

<!-- LOGIN -->
<div class="container" id="loginPage">
    <div class="header">
        <h3>College Administration System (CAS)</h3>
    </div>

    <div class="login-box">
        <h1>Login</h1>

        <input type="email" id="email" placeholder="User id">
        <input type="password" id="password" placeholder="Password">

        <br>

        <button onclick="login()">Login</button>
        <button onclick="resetForm()">Reset</button>

        <p class="error" id="errorMsg">Invalid Email or Password</p>
    </div>
</div>

<!-- REPORT CARD -->
<div class="container" id="reportCard">

    <div class="grade-title">GRADE - CARD</div>

    <p style="text-align:center;"><b>Bachelor Of Business Administration (International Business)</b></p>

    <div class="info">
